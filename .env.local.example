# Copy to .env.local and fill in real values. .env.local is gitignored.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App URL (used in WhatsApp/SMS approval links). On Vercel, set to https://yourdomain.vercel.app ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Twilio (WhatsApp Business API or SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # e.g. "whatsapp:+14155238886" for sandbox, or "+1XXXXXXXXXX" for SMS
NOTIFICATION_CHANNEL=whatsapp   # 'whatsapp' or 'sms'
OWNER_PHONE=               # +1XXXXXXXXXX — where approvals + sale alerts go

# --- Internal ---
APPROVAL_TOKEN_SECRET=     # any 32+ char random string; used to sign approval links
